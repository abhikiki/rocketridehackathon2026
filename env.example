# Synced by the RocketRide VS Code extension
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=replace-with-your-rocketride-api-key

# Track B model and integrations
ROCKETRIDE_OPENAI_KEY=replace-with-your-openai-api-key
ROCKETRIDE_GITHUB_TOKEN=replace-with-a-fine-grained-github-token
ROCKETRIDE_GITHUB_REPO=abhikiki/rocketridehackathon2026
GITHUB_WEBHOOK_SECRET=replace-with-a-random-github-webhook-secret

# Supavisor session-pooler values from Supabase's Connect dialog
ROCKETRIDE_SUPABASE_HOST=aws-0-your-region.pooler.supabase.com:5432
ROCKETRIDE_SUPABASE_USER=postgres.your-project-ref
ROCKETRIDE_SUPABASE_PASSWORD=replace-with-your-database-password
ROCKETRIDE_SUPABASE_DATABASE=postgres

# Pipeline 2 deployment URL, used by Pipeline 3 after a PR is merged
ROCKETRIDE_INCIDENT_WEBHOOK_URL=https://replace-with-pipeline-2-webhook
ROCKETRIDE_INCIDENT_WEBHOOK_KEY=replace-with-an-internal-webhook-secret
PIPELINE2_RELAY_KEY=use-the-same-internal-webhook-secret
ROCKETRIDE_REOPEN_WINDOW_MINUTES=30

# Track A victim app (full, percent-encoded pooler URI for Vercel)
SUPABASE_POOLER_URL=postgresql://postgres.project-ref:password@pooler-host:5432/postgres
PIPELINE2_RELAY_URL=https://replace-with-track-b-relay/api/incident

# Dashboard build-time public values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

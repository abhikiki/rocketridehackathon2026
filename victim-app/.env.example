# Supavisor pooler connection string from the Supabase dashboard (Connect
# button) — NOT the IPv6-only direct connection.
# e.g. postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_POOLER_URL=

# RocketRide server connection (auto-managed by the RocketRide VS Code
# extension in most setups — set manually if running standalone).
ROCKETRIDE_URI=https://api.rocketride.ai
ROCKETRIDE_APIKEY=

# Track B's relay in front of Pipeline 2 (Incident Management). Get these
# from your teammate once their relay is deployed.
PIPELINE2_RELAY_URL=
PIPELINE2_RELAY_KEY=
